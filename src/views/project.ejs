<%- include('partials/header') %>
    <main>
        <h1>
            <%= project.title %>
        </h1>
 
        <div class="project-details">
 
            <p class="project-description">
                <%= project.description %>
            </p>
 
            <ul class="details-list">
                <li>
                    <strong>Date:</strong>
                    <%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' ,
                        day: 'numeric' , timeZone: 'UTC' }) %>
                </li>
                <li>
                    <strong>Location:</strong>
                    <%= project.event_location %>
                </li>
                <li>
                    <strong>Organization:</strong>
                    <a href="/organization/<%= project.organization_id %>">
                        <%= project.organization_name %>
                    </a>
                </li>
                <li>
                    <strong>Categories:</strong>
                    <% categories.forEach(category => { %>
                        <a href="/category/<%= category.category_id %>">
                            <%= category.name %>
                        </a>
                    <% }) %>
                </li>
            </ul>
            <% if (isLoggedIn) { %>

                <% if (!volunteerStatus) { %>

                    <form
                        action="/project/<%= project.project_id %>/volunteer"
                        method="POST">

                        <button type="submit">
                            Volunteer for this Project
                        </button>

                    </form>

                <% } else { %>

                    <p>
                        You are volunteering for this project.
                    </p>

                    <form
                        action="/project/<%= project.project_id %>/remove-volunteer"
                        method="POST">

                        <input
                            type="hidden"
                            name="source"
                            value="project">

                        <button type="submit">
                            Remove Volunteer Signup
                        </button>

                    </form>

                <% } %>

            <% } %>

            <p>
                <% if (user && user.role_name === 'admin') { %>
                    <a href="/project/<%= project.project_id %>/assign-categories">
                        Edit Categories
                    </a>
                <% } %>
            </p>
            <p>
                <% if (user && user.role_name === 'admin') { %>
                    <a href="/edit-project/<%= project.project_id %>">
                        Edit Project
                    </a>
                <% } %>
            </p>
        </div>
    </main>
<%- include('partials/footer') %>