<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Upcoming Service Projects</h2>

    <ul>
        <% projects.forEach(project => { %>

            <li>
                <%= new Date(project.project_date).toLocaleDateString(
                    'en-US',
                    {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                        timeZone: 'UTC'
                    }
                ) %>:

                <strong>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </strong>

                (
                    <a href="/organization/<%= project.organization_id %>">
                        <%= project.organization_name %>
                    </a>
                )
            </li>

        <% }); %>
    </ul>
    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/new-project">Add a New Service Project</a></p>
    <% } %>
</main>

<%- include('partials/footer') %>