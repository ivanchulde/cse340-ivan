<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <form action="/new-project" method="POST">

        <div class="form-group">
            <label for="organizationId">Organization</label>

            <select
                id="organizationId"
                name="organizationId"
                required
            >
                <option value="">Select an organization</option>

                <% organizations.forEach(organization => { %>
                    <option value="<%= organization.organization_id %>">
                        <%= organization.name %>
                    </option>
                <% }) %>

            </select>
        </div>

        <div class="form-group">
            <label for="title">Project Title</label>

            <input
                type="text"
                id="title"
                name="title"
                maxlength="200"
                required
            >
        </div>

        <div class="form-group">
            <label for="description">Description</label>

            <textarea
                id="description"
                name="description"
                maxlength="1000"
                required
            ></textarea>
        </div>

        <div class="form-group">
            <label for="eventLocation">Location</label>

            <input
                type="text"
                id="eventLocation"
                name="eventLocation"
                maxlength="200"
                required
            >
        </div>

        <div class="form-group">
            <label for="projectDate">Project Date</label>

            <input
                type="date"
                id="projectDate"
                name="projectDate"
                required
            >
        </div>

        <button type="submit">
            Create Project
        </button>

    </form>

</main>

<%- include('partials/footer') %>